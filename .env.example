# OpenRouter — https://openrouter.ai/keys (модели OpenAI, Anthropic, Google и др.)
OPENROUTER_API_KEY=sk-or-v1-...

# Основная модель (рекомендуется vision для take_screenshot)
OPENROUTER_MODEL=google/gemini-2.0-flash-001
OPENROUTER_VISION_MODEL=google/gemini-2.0-flash-001

# Опционально: anthropic/claude-3.5-sonnet, openai/gpt-4o (может быть geo-block)
# OPENROUTER_TEMPERATURE=0.2
# OPENROUTER_MAX_TOKENS=8192
# OPENROUTER_TIMEOUT=180
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_HTTP_REFERER=
# OPENROUTER_APP_TITLE=ai-browser-agent

# Прокси только для API (браузер без VPN)
# OPENROUTER_PROXY=http://127.0.0.1:7890

# Браузер: видимый, не headless
# PLAYWRIGHT_HEADLESS=0

# Постоянная сессия Playwright (если без CDP)
# USER_DATA_DIR задаётся в config.py → репозиторий/.pw-user-data

# Подключение к вашему Chrome (лучше для hh.ru, почты и т.д.)
# PLAYWRIGHT_CDP_URL=http://127.0.0.1:9222
# PLAYWRIGHT_FOLLOW_NEWEST_TAB=1

# PLAYWRIGHT_CHANNEL=chrome
# PLAYWRIGHT_EXECUTABLE=C:\Program Files\Google\Chrome\Application\chrome.exe
# PLAYWRIGHT_GOTO_WAIT=domcontentloaded

# Контекст страницы
# PAGE_ARIA_DEPTH=12
# MAX_ARIA_SNAPSHOT_CHARS=14000
# ARIA_SNAPSHOT_TIMEOUT_MS=45000

# Агент
# MAX_AGENT_STEPS=40
# AGENT_DEBUG_LLM=1
# AGENT_SCREENSHOT_DIR=
# VISION_MAX_IMAGES_PER_STEP=4

# Ограничение навигации только на хосты из URL в задаче (через запятую)
# BROWSER_STRICT_ROOT_ONLY_HOSTS=
